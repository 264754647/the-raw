cursor: 'pointer',\n            transition: 'all 0.3s'\n          }}>\n            BROWSE COLLECTION\n          </Link>\n        </div>\n\n      </div>\n\n      {/* Images Section */}\n      <div style={{\n        display: 'grid',\n        gridTemplateColumns: 'repeat(2, 1fr)',\n        gap: '0',\n        padding: '0',\n        backgroundColor: '#fff'\n      }}>\n        {/* Picture 1 */}\n        <Link to=\"/\" style={{\n          position: 'relative',\n          overflow: 'hidden',\n          textDecoration: 'none',\n          cursor: 'pointer',\n          display: 'block'\n        }}>\n          <img\n            src=\"/HomePagePics1.png\"\n            alt=\"Collection 1\"\n            style={{\n              width: '100%',\n              height: 'auto',\n              objectFit: 'cover',\n              transition: 'transform 0.3s ease'\n            }}\n          />\n          <div style={{\n            position: 'absolute',\n            top: '50%',\n            left: '50%',\n            transform: 'translate(-50%, -50%)',\n            backgroundColor: 'rgba(0, 0, 0, 0.3)',\n            padding: '20px 40px',\n              transition: 'background-color 0.3s ease'\n          }}>\n            <p style={{\n              fontSize: '18px',\n              fontFamily: 'Helvetica, Arial, sans-serif',\n              fontWeight: '300',\n              color: '#fff',\n              margin: 0,\n              letterSpacing: '1px',\n              textAlign: 'center'\n            }}>\n              COLLECTION 1\n            </p>\n          </div>\n        </Link>\n\n        {/* Picture 2 */}\n        <Link to=\"/\" style={{\n          position: 'relative',\n          overflow: 'hidden',\n          textDecoration: 'none',\n          cursor: 'pointer',\n          display: 'block'\n        }}>\n          <img\n            src=\"/HomePagePics2.png\"\n            alt=\"Collection 2\"\n            style={{\n              width: '100%',\n              height: 'auto',\n              objectFit: 'cover',\n              transition: 'transform 0.3s ease'\n            }}\n          />\n          <div style={{\n            position: 'absolute',\n            top: '50%',\n            left: '50%',\n            transform: 'translate(-50%, -50%)',\n            backgroundColor: 'rgba(0, 0, 0, 0.3)',\n            padding: '20px 40px',\n              transition: 'background-color 0.3s ease'\n          }}>\n            <p style={{\n              fontSize: '18px',\n              fontFamily: 'Helvetica, Arial, sans-serif',\n              fontWeight: '300',\n              color: '#fff',\n              margin: 0,\n              letterSpacing: '1px',\n              textAlign: 'center'\n            }}>\n              COLLECTION 2\n            </p>\n          </div>\n        </Link>\n\n        {/* Picture 3 */}\n        <Link to=\"/\" style={{\n          position: 'relative',\n          overflow: 'hidden',\n          textDecoration: 'none',\n          cursor: 'pointer',\n          display: 'block'\n        }}>\n          <img\n            src=\"/HomePagePics3.png\"\n            alt=\"Collection 3\"\n            style={{\n              width: '100%',\n              height: 'auto',\n              objectFit: 'cover',\n              transition: 'transform 0.3s ease'\n            }}\n          />\n          <div style={{\n            position: 'absolute',\n            top: '50%',\n            left: '50%',\n            transform: 'translate(-50%, -50%)',\n            backgroundColor: 'rgba(0, 0, 0, 0.3)',\n            padding: '20px 40px',\n              transition: 'background-color 0.3s ease'\n          }}>\n            <p style={{\n              fontSize: '18px',\n              fontFamily: 'Helvetica, Arial, sans-serif',\n              fontWeight: '300',\n              color: '#fff',\n              margin: 0,\n              letterSpacing: '1px',\n              textAlign: 'center'\n            }}>\n              COLLECTION 3\n            </p>\n          </div>\n        </L